# ── Provider ──────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ── Required for LLM_PROVIDER=openai ──────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Required for LLM_PROVIDER=azure_openai ─────────────────
# AZURE_OPENAI_API_KEY=your-azure-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Optional alternates ──────────────────────────────────
# GEMINI_API_KEY=your-gemini-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── Tuning ───────────────────────────────────────────────
# LLM_CONCURRENCY=8          # max parallel LLM calls
# LLM_RETRY_ATTEMPTS=3       # retries on 429 / 5xx
# LLM_RETRY_BASE_DELAY=2.0   # base delay in seconds for exponential backoff
# LLM_TEMPERATURE=0
# LLM_MAX_TOKENS=1400

# ── Evaluation cost assumptions ──────────────────────────
# LLM_INPUT_COST_PER_1M=0.15
# LLM_OUTPUT_COST_PER_1M=0.60
